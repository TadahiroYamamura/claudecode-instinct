observer:
  enabled: true
  trigger_every: 20
  active_hours: "800-2300"

confidence:
  thresholds:
    low: 3
    medium: 6
    high: 11

dedup:
  auto_run_before_push: false
  similarity_model: "bigram"    # bigram | trigram | overlap
  similarity_threshold: 0.15   # この値未満のペアはHaikuに送らない

dolt:
  refs: refs/dolt/{{ .ProjectName }}/
  branch: {{ .Branch }}
  team_branch: {{ .TeamBranch }}
  remote_url: {{ .RemoteURL }}
